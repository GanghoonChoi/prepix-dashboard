# Copy to .env.local for local dev, and set these in your host (Vercel/etc.) for
# production. All NEXT_PUBLIC_* vars are inlined into the client bundle at build
# time — they are NOT secret, but they DO need to be present at build time.

# Base URL of the prepix-backend API (NestJS). The client appends /v2 itself.
# Local dev: http://localhost:3000
# Production: the deployed backend origin (e.g. https://api.prepix.ai)
# NOTE: the deployed dashboard origin must be added to the backend's
# CORS_ALLOWED_ORIGINS or the browser will block every request.
NEXT_PUBLIC_API_URL=http://localhost:3000

# This dashboard's own public origin — used to resolve OpenGraph/social image
# URLs. e.g. https://app.prepix.ai
NEXT_PUBLIC_SITE_URL=http://localhost:3001

# Paddle client-side token (public, pri_/live_ or test token from the Paddle
# dashboard). Enables the in-page checkout overlay. If unset, checkout still
# works via the backend hosted-checkout redirect (worse UX, leaves the app).
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=

# "sandbox" or "production" — must match the token above and the backend's
# PADDLE_ENVIRONMENT. Defaults to "sandbox" when unset.
NEXT_PUBLIC_PADDLE_ENVIRONMENT=sandbox

# Google OAuth *Web* client id for "Sign in with Google" (Google Identity
# Services). Public, no secret. Must equal the backend's GOOGLE_OAUTH_WEB_CLIENT_ID,
# and the dashboard origin must be listed under the client's "Authorized
# JavaScript origins" in Google Cloud Console (incl. http://localhost:3001 for
# local dev). If unset, the Google button is hidden.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
